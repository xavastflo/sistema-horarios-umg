APP_NAME="Sistema de Horarios Universitarios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos ────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=horarios_universitarios
DB_USERNAME=horarios_user
DB_PASSWORD=CambiarEstaPassword123!
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Sanctum ─────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,127.0.0.1:5173

# ── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Sesión ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache ────────────────────────────────────────────────────
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Sistema académico ────────────────────────────────────────
# Máximo de cursos que puede impartir un docente por período
# (pendiente de confirmación institucional: 6 u 8)
MAX_CURSOS_DOCENTE=6

# Duración mínima/máxima de bloques en minutos
BLOQUE_DURACION_MIN=50
BLOQUE_DURACION_MAX=180

NOMBRE_SISTEMA="Sistema de Horarios Universitarios"
